# FIWARE authentication (optional; required if your broker enforces auth)
FIWARE_AUTH_TOKEN=your-fiware-auth-token

# Orion / current-state API
ORION_URL=http://your-orion-host:1027
ORION_ENTITIES_PATH=/ngsi-ld/v1/entities

# QuantumLeap / historical API
QUANTUMLEAP_URL=http://your-quantumleap-host:8669
QUANTUMLEAP_ENTITIES_PATH=/v2/entities
QUANTUMLEAP_ATTRS_PATH=/v2/attrs

# Default FIWARE tenant/service
FIWARE_SERVICE=your-fiware-service
NGSILD_TENANT=your-ngsild-tenant

# JSON-LD context
FIWARE_CONTEXT=https://example.com/your-context.jsonld

# Defaults for entity queries
DEFAULT_ENTITY_TYPE=your-entity-type
DEFAULT_ENTITY_ID_PREFIX=urn:ngsi-ld:your-entity-type
DEFAULT_ATTRS=airTemperature
DEFAULT_OPTIONS=keyValues

# Query safety defaults
DEFAULT_LIMIT=100
MAX_LIMIT=1000
DEFAULT_OFFSET=0
